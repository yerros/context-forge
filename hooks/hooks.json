{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "CTX=context; { [ -f .forge/progress-tracker.md ] || [ -f .forge/context-digest.md ]; } && CTX=.forge; if [ -f \"$CTX/context-digest.md\" ]; then printf '%s\\n' \"[Context Forge] This project uses the Context Forge methodology with tiered context loading; its context directory is $CTX/ (substitute it wherever skills mention context/). The compact digest below is Tier 1 — always in effect. Read further context files ONLY as the task requires (see the tier map at the bottom of the digest); when starting implementation work, also read $CTX/progress-tracker.md for live state. Never guess: if a decision depends on a file you have not read, read it first. Digest:\"; cat \"$CTX/context-digest.md\"; elif [ -f \"$CTX/progress-tracker.md\" ]; then printf '%s\\n' \"[Context Forge] This project uses the Context Forge methodology; its context directory is $CTX/. Before implementing or making any architectural decision, read the entry point (CLAUDE.md or AGENTS.md) and the files in $CTX/ in order. Honor the invariants in $CTX/architecture.md and the rules in $CTX/ai-workflow-rules.md. Current project state from $CTX/progress-tracker.md:\"; cat \"$CTX/progress-tracker.md\"; fi",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/skills/forge-init/scripts/migrate-schema.sh\" --auto 2>/dev/null || true",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/skills/forge-reconcile/scripts/detect-oob.sh\" --hook 2>/dev/null || true",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "[ -f \"$HOME/.claude/forge-office/autostart\" ] && bash \"${CLAUDE_PLUGIN_ROOT}/skills/forge-office/scripts/forge-office.sh\" start --hook 2>/dev/null || true",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/now-status.sh\" tool",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/hook-logger.sh\" pre",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "^(Write|Edit|MultiEdit|NotebookEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/guard.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "^Skill$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/skill-status.sh\" capture",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "^(Task|Agent)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/agent-status.sh\" start",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/hook-logger.sh\" post",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "^(Task|Agent)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/agent-status.sh\" stop",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/hook-logger.sh\" subagent-stop",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/agent-status.sh\" stop",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/skill-status.sh\" capture",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/office-inbox.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/hook-logger.sh\" user-prompt",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/hook-logger.sh\" stop-pre",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/track.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/skill-status.sh\" idle",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/now-status.sh\" clear",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/agent-status.sh\" turnend",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/hook-logger.sh\" stop",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/hook-logger.sh\" session-end",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/agent-status.sh\" end",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
